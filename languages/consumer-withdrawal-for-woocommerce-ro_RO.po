#. Plugin Name of the plugin
#: consumer-withdrawal-for-woocommerce.php
msgid "Consumer Withdrawal for WooCommerce"
msgstr "Retragerea consumatorului pentru WooCommerce"

#. Plugin URI of the plugin
#: consumer-withdrawal-for-woocommerce.php
msgid "https://wordpress.org/plugins/consumer-withdrawal-for-woocommerce/"
msgstr ""

#. Description of the plugin
#: consumer-withdrawal-for-woocommerce.php
msgid ""
"Adds a consumer withdrawal request button to WooCommerce orders according to "
"EU legislation."
msgstr ""
"Adaugă un buton pentru solicitarea retragerii de către consumator la "
"comenzile WooCommerce, în conformitate cu legislația UE."

#. Author of the plugin
#: consumer-withdrawal-for-woocommerce.php
msgid "Adrian Webdesign"
msgstr ""

#. Author URI of the plugin
#: consumer-withdrawal-for-woocommerce.php
msgid "https://adrianwebdesign.ro"
msgstr ""

#: consumer-withdrawal-for-woocommerce.php:88
msgid ""
"Consumer Withdrawal for WooCommerce requires WooCommerce to be installed and "
"activated."
msgstr ""
"Consumer Withdrawal for WooCommerce necesită ca WooCommerce să fie instalat "
"și activat."

