#. Plugin Name of the plugin
#: consumer-withdrawal-for-woocommerce.php
msgid "Consumer Withdrawal for WooCommerce"
msgstr "Desistimiento del consumidor para WooCommerce"

#. Plugin URI of the plugin
#: consumer-withdrawal-for-woocommerce.php
msgid "https://wordpress.org/plugins/consumer-withdrawal-for-woocommerce/"
msgstr ""

#. Description of the plugin
#: consumer-withdrawal-for-woocommerce.php
msgid ""
"Adds a consumer withdrawal request button to WooCommerce orders according to "
"EU legislation."
msgstr ""
"Añade un botón de solicitud de desistimiento del consumidor a los pedidos de "
"WooCommerce, de acuerdo con la legislación de la UE."

#. Author of the plugin
#: consumer-withdrawal-for-woocommerce.php
msgid "Adrian Webdesign"
msgstr ""

#. Author URI of the plugin
#: consumer-withdrawal-for-woocommerce.php
msgid "https://adrianwebdesign.ro"
msgstr ""

#: consumer-withdrawal-for-woocommerce.php:88
msgid ""
"Consumer Withdrawal for WooCommerce requires WooCommerce to be installed and "
"activated."
msgstr ""
"Consumer Withdrawal para WooCommerce requiere que WooCommerce esté instalado "
"y activado."

